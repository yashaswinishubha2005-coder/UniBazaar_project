<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp"
    android:padding="16dp"
    android:background="@drawable/light_card_background">

    <ImageView
        android:id="@+id/imageViewListing"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_unibazaar_logo"
        android:contentDescription="Listing image"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/textViewItemTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="#241B35" />

    <TextView
        android:id="@+id/textViewItemDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textSize="14sp"
        android:textColor="#5B506E"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/textViewItemPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs. 0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/textViewItemCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textSize="13sp"
        android:textColor="#6F6484"
        android:layout_marginTop="6dp" />

</LinearLayout>