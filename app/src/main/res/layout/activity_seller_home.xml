<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seller Studio"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/ub_deep"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage products, refresh listings, and respond quickly to interested buyers."
            android:textSize="14sp"
            android:textColor="@color/ub_text_secondary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="136dp"
                android:layout_columnWeight="1"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="14dp"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/ub_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Launch a new item into the marketplace."
                    android:textColor="@color/ub_soft"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/buttonAddListing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Listing"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/button_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="136dp"
                android:layout_columnWeight="1"
                android:background="@drawable/light_card_background"
                android:orientation="vertical"
                android:padding="14dp"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/ub_deep" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See every product you have already posted."
                    android:textColor="@color/ub_text_secondary"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/buttonMyListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="My Listings"
                    android:textStyle="bold"
                    android:textColor="@color/ub_deep"
                    android:background="@drawable/button_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="136dp"
                android:layout_columnWeight="1"
                android:background="@drawable/grid_tile_secondary"
                android:orientation="vertical"
                android:padding="14dp"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chats"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/ub_deep" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reply to buyer questions and close deals faster."
                    android:textColor="@color/ub_text_primary"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/buttonViewChats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View Chats"
                    android:textStyle="bold"
                    android:textColor="@color/ub_deep"
                    android:background="@drawable/button_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="136dp"
                android:layout_columnWeight="1"
                android:background="@drawable/grid_tile_primary"
                android:orientation="vertical"
                android:padding="14dp"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exit"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign out safely when you are done for the day."
                    android:textColor="@color/ub_surface"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/buttonLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Logout"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/button_primary" />
            </LinearLayout>
        </GridLayout>
    </LinearLayout>
</ScrollView>
