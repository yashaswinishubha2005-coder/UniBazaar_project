<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="18dp"
        android:layout_marginBottom="14dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buyer Chats"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/ub_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="See the latest questions from interested buyers and keep the conversation moving."
            android:textSize="14sp"
            android:textColor="@color/ub_soft"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textViewEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="No buyer messages yet"
        android:textColor="@color/ub_text_secondary"
        android:textSize="16sp"
        android:layout_marginTop="32dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewChatUsers"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</LinearLayout>
